# Copy to .env and adjust. Never commit real credentials.

# Runtime
GATEWAY_ENV=dev
GATEWAY_HTTP_ADDR=:8080
GATEWAY_LOG_LEVEL=info
GATEWAY_READ_TIMEOUT=15s
GATEWAY_WRITE_TIMEOUT=30s
GATEWAY_SHUTDOWN_TIMEOUT=20s

# Provider credentials. Configure at least one provider — the gateway fails to
# start if none is set. Bedrock also requires AWS_REGION plus both key vars
# below (AWS_SESSION_TOKEN is optional, for temporary/STS credentials only).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Routing table for POST /v1/chat/completions: a JSON object mapping a logical
# model name to an ordered fallback chain of {provider, model} targets. Every
# provider referenced here must have credentials configured above.
# GATEWAY_ROUTES={"chat-default":[{"provider":"anthropic","model":"claude-opus-4-8"},{"provider":"openai","model":"gpt-4o"}]}

# Cost attribution overrides: a JSON object of provider -> model -> USD rate
# per 1M input/output tokens. Merged over the gateway's built-in rate table;
# entries here take precedence. Set this when a model isn't in the built-in
# table, or when your negotiated rate differs from list price.
# GATEWAY_PRICING={"anthropic":{"claude-opus-4-8":{"input_per_1m":15,"output_per_1m":75}}}
